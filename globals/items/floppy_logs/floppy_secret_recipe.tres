script = ExtResource("1_nv2td")
id = "floppy_007"
name = "Floppy Log 007"
description = "[pretext]Engineering Note[/pretext]
[content]
Should we have an emergency and gotta run don't leave [MACHINE_NAME] behind.
The Supercharged Relic is the last tecnology available to do so.
We developed a way to supercharge an Aether Chamber.
Put this on the assembly line with the Sync Module, a Tesseract and a big diamond.
Be aware that Tesseracts are expensive and rare. Don't waste it.
[/content]"
texture = ExtResource("2_1gw1t")
usable_once = true
is_pickable = true
